---
import Layout from '../../layouts/Layout.astro';

interface Release {
  id: number;
  tag_name: string;
  name: string;
  body: string;
  published_at: string;
  html_url: string;
  prerelease: boolean;
  draft: boolean;
  assets: { name: string; browser_download_url: string; download_count: number }[];
  author: { login: string; avatar_url: string; html_url: string };
}

let releases: Release[] = [];
let fetchError = false;

try {
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github+json',
    'X-GitHub-Api-Version': '2022-11-28',
  };
  if (import.meta.env.GITHUB_TOKEN) {
    headers['Authorization'] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
  }
  const res = await fetch('https://api.github.com/repos/songtianlun/rivulet/releases?per_page=50', { headers });
  if (res.ok) {
    releases = await res.json();
    releases = releases.filter((r) => !r.draft);
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatDate(iso: string) {
  const d = new Date(iso);
  return `${d.getFullYear()} 年 ${d.getMonth() + 1} 月 ${d.getDate()} 日`;
}

// Simple markdown → HTML: headers, bold, code, lists, links
function mdToHtml(md: string): string {
  if (!md) return '';
  let html = md
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    // headings
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    // bold / italic
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
    // unordered list items
    .replace(/^[*\-] (.+)$/gm, '<li>$1</li>')
    // wrap consecutive <li> in <ul>
    .replace(/(<li>.*<\/li>\n?)+/g, (m) => `<ul>${m}</ul>`)
    // paragraphs: blank lines → paragraph breaks
    .replace(/\n{2,}/g, '</p><p>')
    .replace(/\n/g, '<br/>');
  return `<p>${html}</p>`;
}
---

<Layout
  lang="zh"
  title="更新日志 · 溪流记账"
  description="查看溪流记账（Rivulet）的所有版本发布记录与更新日志。"
>
  <div class="cl-page">
    <!-- ── 顶栏 ── -->
    <header class="cl-header">
      <a href="/zh/" class="cl-back">← 返回首页</a>
      <a href="/zh/changelog" class="cl-logo">
        <img src="/logo.png" alt="Rivulet logo" />
        <span>溪流记账</span>
      </a>
      <a href="/en/changelog" class="cl-lang">EN</a>
    </header>

    <!-- ── 英雄区 ── -->
    <section class="cl-hero">
      <div class="cl-hero-badge">发行记录</div>
      <h1>更新日志</h1>
      <p>溪流记账每个版本的新功能、优化与修复记录</p>
    </section>

    <!-- ── 主内容 ── -->
    <main class="cl-main">
      {(fetchError || releases.length === 0) && (
        <div class="cl-empty-state">
          <div class="cl-empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3>暂无法获取更新日志</h3>
          <p>接口暂时无法访问，请稍后再试。</p>
        </div>
      )}

      <div class="cl-timeline">
        {releases.map((release, idx) => (
          <article class={`cl-release ${release.prerelease ? 'prerelease' : ''}`}>
            <!-- 时间线装饰 -->
            <div class="cl-line-col">
              <div class={`cl-dot ${idx === 0 && !release.prerelease ? 'latest' : ''} ${release.prerelease ? 'pre' : ''}`}></div>
            </div>

            <!-- 内容卡片 -->
            <div class="cl-card">
              <div class="cl-card-head">
                <div class="cl-version-row">
                  <a class="cl-version" href={release.html_url} target="_blank" rel="noopener">
                    {release.name || release.tag_name}
                  </a>
                  {idx === 0 && !release.prerelease && <span class="cl-badge latest-badge">最新</span>}
                  {release.prerelease && <span class="cl-badge pre-badge">预发布</span>}
                </div>
                <div class="cl-meta">
                  <img class="cl-avatar" src={release.author.avatar_url} alt={release.author.login} width="20" height="20" />
                  <span>{release.author.login}</span>
                  <span class="cl-sep">·</span>
                  <time>{formatDate(release.published_at)}</time>
                  <span class="cl-sep">·</span>
                  <a href={release.html_url} target="_blank" rel="noopener" class="cl-tag-link">{release.tag_name}</a>
                </div>
              </div>

              {release.body && (
                <div class="cl-body" set:html={mdToHtml(release.body)} />
              )}

              {release.assets.length > 0 && (
                <div class="cl-assets">
                  <div class="cl-assets-label">下载</div>
                  <div class="cl-assets-list">
                    {release.assets.map((asset) => (
                      <a class="cl-asset" href={asset.browser_download_url} target="_blank" rel="noopener">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        {asset.name}
                        <span class="cl-dl-count">{asset.download_count.toLocaleString()}</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </main>

    <footer class="cl-footer">
      <p>© 2025 Rivulet · 溪流记账 · <a href="https://github.com/songtianlun/rivulet" target="_blank" rel="noopener">GitHub</a></p>
    </footer>
  </div>
</Layout>

<style>
  /* ── 整体布局 ── */
  .cl-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: 'Noto Sans SC', 'Plus Jakarta Sans', sans-serif;
    background: #faf9ff;
    color: #1e1b2e;
  }

  /* ── 顶栏 ── */
  .cl-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 1px solid #ede9fe;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .cl-back {
    font-size: 0.875rem;
    color: #8B5CF6;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .cl-back:hover { opacity: 0.7; }
  .cl-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1rem;
    color: #1e1b2e;
    text-decoration: none;
  }
  .cl-logo img { width: 28px; height: 28px; border-radius: 6px; }
  .cl-lang {
    font-size: 0.875rem;
    color: #8B5CF6;
    text-decoration: none;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border: 1px solid #ede9fe;
    border-radius: 20px;
    transition: background 0.2s;
  }
  .cl-lang:hover { background: #f5f3ff; }

  /* ── 英雄区 ── */
  .cl-hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    background: linear-gradient(135deg, #f5f3ff 0%, #faf9ff 60%, #ede9fe 100%);
    border-bottom: 1px solid #ede9fe;
  }
  .cl-hero-badge {
    display: inline-block;
    background: #ede9fe;
    color: #7C3AED;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }
  .cl-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #1e1b2e;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .cl-hero p {
    font-size: 1.05rem;
    color: #6d6a84;
    margin-bottom: 1.75rem;
  }
  .cl-github-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1e1b2e;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .cl-github-btn:hover { background: #2d1f6e; transform: translateY(-1px); }

  /* ── 主内容 ── */
  .cl-main {
    flex: 1;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .cl-error, .cl-empty {
    text-align: center;
    padding: 3rem 1rem;
    color: #6d6a84;
    font-size: 0.95rem;
  }
  .cl-error a, .cl-empty a { color: #8B5CF6; }
  .cl-empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: #9b93c4;
  }
  .cl-empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #f0edff;
    color: #c4b5fd;
    margin-bottom: 1.25rem;
  }
  .cl-empty-state h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #6d6a84;
    margin-bottom: 0.5rem;
  }
  .cl-empty-state p {
    font-size: 0.9rem;
    color: #9b93c4;
  }

  /* ── 时间线 ── */
  .cl-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .cl-release {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 0 1.25rem;
    align-items: stretch;
    padding-bottom: 1.5rem;
  }

  /* 左侧竖线 + 圆点 */
  .cl-line-col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 1.4rem;
  }
  /* 连续竖线：从顶部延伸到下一行（最后一项止于圆点中心） */
  .cl-line-col::before {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    bottom: -1.5rem; /* 覆盖 cl-release 的 padding-bottom，与下一行相接 */
    width: 2px;
    background: #c4b5fd;
    z-index: 0;
  }
  .cl-release:last-child .cl-line-col::before {
    bottom: auto;
    height: calc(1.4rem + 7px); /* padding-top + 半个圆点高度 */
  }
  .cl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #c4b5fd;
    border: 3px solid #faf9ff;
    box-shadow: 0 0 0 2px #c4b5fd;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .cl-dot.latest {
    background: #8B5CF6;
    box-shadow: 0 0 0 3px #c4b5fd, 0 0 12px #a78bfa88;
  }
  .cl-dot.pre {
    background: #f59e0b;
    box-shadow: 0 0 0 2px #fcd34d;
  }

  /* 卡片 */
  .cl-card {
    background: #fff;
    border: 1px solid #ede9fe;
    border-radius: 14px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px #8B5CF608;
    transition: box-shadow 0.2s, transform 0.15s;
  }
  .cl-card:hover {
    box-shadow: 0 6px 24px #8B5CF618;
    transform: translateY(-2px);
  }
  .cl-release.prerelease .cl-card {
    border-color: #fde68a;
    background: #fffdf0;
  }

  .cl-card-head { margin-bottom: 1rem; }
  .cl-version-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }
  .cl-version {
    font-size: 1.15rem;
    font-weight: 700;
    color: #7C3AED;
    text-decoration: none;
  }
  .cl-version:hover { text-decoration: underline; }

  .cl-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .latest-badge { background: #7C3AED; color: #fff; }
  .pre-badge { background: #f59e0b; color: #fff; }

  .cl-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #9b93c4;
    flex-wrap: wrap;
  }
  .cl-avatar {
    border-radius: 50%;
    vertical-align: middle;
  }
  .cl-sep { opacity: 0.4; }
  .cl-tag-link {
    color: #8B5CF6;
    text-decoration: none;
    font-family: monospace;
    font-size: 0.8rem;
  }
  .cl-tag-link:hover { text-decoration: underline; }

  /* 正文 */
  .cl-body {
    font-size: 0.93rem;
    line-height: 1.75;
    color: #3d3a55;
    border-top: 1px solid #f0edff;
    padding-top: 1rem;
    margin-top: 0.25rem;
  }
  .cl-body :global(h1),
  .cl-body :global(h2),
  .cl-body :global(h3) {
    font-weight: 700;
    color: #1e1b2e;
    margin: 1rem 0 0.4rem;
  }
  .cl-body :global(h2) { font-size: 1rem; }
  .cl-body :global(h3) { font-size: 0.95rem; }
  .cl-body :global(ul) {
    padding-left: 1.4rem;
    margin: 0.5rem 0;
  }
  .cl-body :global(li) { margin: 0.2rem 0; }
  .cl-body :global(code) {
    background: #f0edff;
    color: #7C3AED;
    font-size: 0.85em;
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
  }
  .cl-body :global(a) { color: #8B5CF6; }
  .cl-body :global(strong) { color: #1e1b2e; }
  .cl-body :global(p) { margin: 0.4rem 0; }

  /* 下载区 */
  .cl-assets {
    margin-top: 1.25rem;
    border-top: 1px solid #f0edff;
    padding-top: 1rem;
  }
  .cl-assets-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9b93c4;
    margin-bottom: 0.5rem;
  }
  .cl-assets-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .cl-asset {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #6d6a84;
    background: #f5f3ff;
    border: 1px solid #ede9fe;
    border-radius: 6px;
    padding: 0.3rem 0.75rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .cl-asset:hover { background: #ede9fe; color: #7C3AED; }
  .cl-dl-count {
    font-size: 0.75rem;
    color: #9b93c4;
    background: #ede9fe;
    border-radius: 4px;
    padding: 0.05rem 0.35rem;
  }

  /* ── Footer ── */
  .cl-footer {
    text-align: center;
    padding: 1.5rem;
    font-size: 0.82rem;
    color: #9b93c4;
    border-top: 1px solid #ede9fe;
  }
  .cl-footer a { color: #8B5CF6; text-decoration: none; }

  /* ── 响应式 ── */
  @media (max-width: 600px) {
    .cl-header { padding: 0.75rem 1rem; }
    .cl-hero { padding: 2.5rem 1rem 2rem; }
    .cl-main { padding: 2rem 1rem; }
    .cl-card { padding: 1.1rem; }
    .cl-release { grid-template-columns: 28px 1fr; gap: 0 0.75rem; }
  }
</style>
