---
import Layout from '../../layouts/Layout.astro';
import SharedNav from '../../components/SharedNav.jsx';
---

<Layout
  lang="zh"
  title="留言板 · 溪流记账"
  description="欢迎在留言板留下你的想法、建议或反馈，一起参与 Rivulet 的成长。"
>
  <SharedNav client:load lang="zh" activePage="guestbook" />
  <div class="guestbook-page">

    <main class="gb-main">
      <div class="gb-hero">
        <h1>留言板</h1>
        <p>有什么想说的？欢迎留下你的想法、建议或反馈，一起让溪流记账变得更好。💬</p>
      </div>

      <div class="gb-comments">
        <script src="https://giscus.app/client.js"
          data-repo="songtianlun/rivulet-docs"
          data-repo-id="R_kgDOSLEHdA"
          data-category="General"
          data-category-id="DIC_kwDOSLEHdM4C8arw"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="preferred_color_scheme"
          data-lang="zh-CN"
          crossorigin="anonymous"
          async>
        </script>
      </div>
    </main>

    <footer class="gb-footer">
      <p>© 2025 Rivulet · 溪流记账 · <a href="https://github.com/songtianlun/rivulet-docs" target="_blank" rel="noopener">GitHub</a></p>
    </footer>
  </div>
</Layout>

<style>
  .guestbook-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: 'Noto Sans SC', 'Plus Jakarta Sans', sans-serif;
    background: #faf9ff;
    color: #1e1b2e;
    padding-top: 64px;
  }

  @media (prefers-color-scheme: dark) {
    .guestbook-page {
      background: #0f0d1a;
      color: #ede9fe;
    }
    .gb-hero p {
      color: #9b93c4 !important;
    }
  }

  .gb-main {
    flex: 1;
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
    padding: clamp(40px, 6vw, 80px) clamp(20px, 4vw, 40px);
  }

  .gb-hero {
    text-align: center;
    margin-bottom: 48px;
  }

  .gb-hero h1 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    margin-bottom: 12px;
    background: linear-gradient(135deg, #8B5CF6, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .gb-hero p {
    font-size: 16px;
    color: #6d6a84;
    line-height: 1.6;
  }

  .gb-comments {
    border-radius: 16px;
    overflow: hidden;
  }

  .gb-footer {
    text-align: center;
    padding: 32px 24px;
    font-size: 13px;
    color: #6d6a84;
  }

  .gb-footer a {
    color: #8B5CF6;
    text-decoration: none;
  }

  .gb-footer a:hover {
    text-decoration: underline;
  }
</style>
